KERNEL_API_KEY=
TZAFON_API_KEY=

# Which game adapter to load (module under src/actuallyabot/games/).
GAME=placeholder

# Override the adapter's default URL — useful while the custom checkers UI
# is at a temporary URL or you want to point the placeholder at a real page.
GAME_URL_OVERRIDE=

# Optional: Kernel profile id to attach (persists logged-in game accounts).
KERNEL_PROFILE=

# Optional: where to POST game-state events for the streamer agent.
# Unset ⇒ events stdout-only.
STREAMER_EVENT_ENDPOINT=

# OBS WebSocket v5. In OBS: Tools → WebSocket Server Settings.
OBS_WS_HOST=127.0.0.1
OBS_WS_PORT=4455
OBS_WS_PASSWORD=

# YouTube RTMP output. Never commit a real stream key.
RTMP_SERVER_URL=rtmp://a.rtmp.youtube.com/live2
STREAM_KEY=

# Optional OBS scene/source sizing for Streambot.
STREAMBOT_CANVAS_WIDTH=1280
STREAMBOT_CANVAS_HEIGHT=720
STREAMBOT_OBSERVER_SCENE="Actuallyabot - Observer"
STREAMBOT_PLAYER_SCENE="Actuallyabot - Player"
STREAMBOT_OPPONENT_SCENE="Actuallyabot - Opponent"

# For streambot-lightcone-obs. Comma-separated URL or Name=URL values.
STREAMBOT_SOURCE_URLS=
STREAMBOT_START_SCENE=Observer
