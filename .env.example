KERNEL_API_KEY=
TZAFON_API_KEY=

# Which game adapter to load (module under src/actuallyabot/games/).
GAME=placeholder

# Override the adapter's default URL — useful while the custom checkers UI
# is at a temporary URL or you want to point the placeholder at a real page.
GAME_URL_OVERRIDE=

# Optional: Kernel profile id to attach (persists logged-in game accounts).
KERNEL_PROFILE=

# Optional: where to POST game-state events for the streamer agent.
# Unset ⇒ events stdout-only.
STREAMER_EVENT_ENDPOINT=
